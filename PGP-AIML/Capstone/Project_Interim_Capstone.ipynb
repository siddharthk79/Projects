      "outputs": [],
      "source": [
        "#Store the performance\n",
        "\n",
        "def get_accuracy(model,accuracy):\n",
        "    global df_accuracy\n",
        "\n",
        "    if 'df_accuracy' not in globals():\n",
        "        df_accuracy = pd.DataFrame(columns=['Model', 'accuracy'])\n",
        "\n",
        "    temp = pd.DataFrame({'Model':[model], 'accuracy':[accuracy]},)\n",
        "    df_accuracy = pd.concat([df_accuracy, temp], ignore_index=True)\n",
        "    print(df_accuracy)"
      ]
